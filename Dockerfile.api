FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1
WORKDIR /app

COPY requirements.txt pyproject.toml README.md example_config.yaml ./
COPY src ./src

RUN python -m pip install --upgrade pip \
    && pip install --no-cache-dir -r requirements.txt \
    && pip install --no-cache-dir -e .

EXPOSE 8000

CMD ["uvicorn", "portfolio_agent.api:app", "--host", "0.0.0.0", "--port", "8000"]
